#!/usr/bin/env bash
#
# tiss — The Intuitive Scripting System
#
# A directory-routed universal script CLI:
#   tiss git clone <repo>   -> runs git/clone.sh from the first overlay tree
#                              that has it (or the core), otherwise passes
#                              through to plain `git` (installing it first
#                              if it is missing).
#
# Overlay trees (TISS_PATH, managed by `tiss self tree`) layer private or
# company script trees over the core: most-specific first, first match wins,
# core always last. Help, completions and --manifest merge all trees.
#
# Invoke under any name you like: symlink or alias this file and every help
# message follows the name you chose (argv[0]-aware):
#   ln -s /path/to/tiss/bin/tiss /usr/local/bin/x
#
set -euo pipefail

# --- self-location -----------------------------------------------------------
# Resolve symlinks portably (macOS ships BSD readlink, which historically has
# no -f), so a symlink like /usr/local/bin/x still finds the real tree.
self="${BASH_SOURCE[0]}"
while [ -L "$self" ]; do
  dir="$(cd -P "$(dirname "$self")" && pwd)"
  self="$(readlink "$self")"
  case "$self" in /*) ;; *) self="$dir/$self" ;; esac
done
TISS_BIN_DIR="$(cd -P "$(dirname "$self")" && pwd)"

TISS_HOME="${TISS_HOME:-$(dirname "$TISS_BIN_DIR")}"
TISS_NAME="$(basename "$0")" # help output follows the alias/symlink name
TISS_SCRIPTS="$TISS_HOME/scripts"
TISS_LIB="$TISS_HOME/lib"
TISS_CONFIG="${TISS_CONFIG:-$HOME/.config/tiss}"
export TISS_HOME TISS_NAME TISS_SCRIPTS TISS_LIB TISS_CONFIG

# Helpers (log*, meta, ensureTool, cfg, tissTrees, ...) shared with all
# scripts. Also loads user config + overlay configs/libs — so config may
# set TISS_DATA/TISS_STATE/TISS_PATH; the defaults below apply after.
. "$TISS_LIB/init.sh"
TISS_DATA="${TISS_DATA:-${XDG_DATA_HOME:-$HOME/.local/share}/tiss/data}"
TISS_STATE="${TISS_STATE:-${XDG_STATE_HOME:-$HOME/.local/state}/tiss}"
export TISS_DATA TISS_STATE
export TISS_PATH="${TISS_PATH:-}" # resolved by config; scripts inherit it

# --- discovery ---------------------------------------------------------------
listScripts() { # listScripts <scripts-root> -> executable files, sorted
  find "$1" -type f | sort | while IFS= read -r f; do
    [ -x "$f" ] && printf '%s\n' "$f"
  done
}

cmdOf() { # cmdOf <scripts-root> <file> -> command words ("git clone")
  local rel="${2#"$1"/}"
  rel="${rel%.*}"
  printf '%s\n' "${rel//\// }"
}

findScript() { # findScript <node> <token> -> matching executable, or fail
  local f
  for f in "$1/$2" "$1/$2".*; do
    if [ -f "$f" ] && [ -x "$f" ]; then
      printf '%s\n' "$f"
      return 0
    fi
  done
  return 1
}

treeTag() { # treeTag <tree-root> -> short label for help/manifest
  if [ "$1" = "$TISS_HOME" ]; then
    echo "core"
  else
    basename "$1"
  fi
}

# resolveInTree <scripts-root> <args...>
# Walks one tree; on a script match sets RESOLVED_SCRIPT/RESOLVED_SHIFT.
# A `_self.*` file in a namespace is that namespace's HANDLER: it catches
# any unmatched subcommand (deepest one wins; exact scripts still beat it),
# so `scripts/ssm/_self.sh` makes `tiss ssm <anything>` yours while
# `scripts/ssm/get.sh` keeps owning `tiss ssm get`.
RESOLVED_SCRIPT=""
RESOLVED_SHIFT=0
resolveInTree() {
  local node="$1" consumed=0 script handler="" handler_consumed=0
  shift
  while :; do
    if script="$(findScript "$node" _self)"; then
      handler="$script"
      handler_consumed=$consumed
    fi
    [ $# -gt 0 ] || break
    case "$1" in -*) break ;; esac # flags never route
    if script="$(findScript "$node" "$1")"; then
      RESOLVED_SCRIPT="$script"
      RESOLVED_SHIFT=$((consumed + 1))
      return 0
    elif [ -d "$node/$1" ]; then
      node="$node/$1"
      consumed=$((consumed + 1))
      shift
    else
      break
    fi
  done
  # Unmatched tokens (or flags) remain: the deepest _self takes them all.
  # Bare namespace landings ($# = 0) still get help, not the handler.
  if [ -n "$handler" ] && [ $# -gt 0 ]; then
    RESOLVED_SCRIPT="$handler"
    RESOLVED_SHIFT=$handler_consumed
    return 0
  fi
  return 1
}

# --- help --------------------------------------------------------------------
showHelp() { # showHelp [namespace words...] — merged across all trees
  local ns="$*"
  echo "usage: $TISS_NAME ${ns:+$ns }<command> [args...]"
  echo
  echo "commands:"
  local tree root node f rel tag seen="
"
  while IFS= read -r tree; do
    root="$tree/scripts"
    node="$root${ns:+/${ns// /\/}}"
    [ -d "$node" ] || continue
    tag="$(treeTag "$tree")"
    while IFS= read -r f; do
      rel="${f#"$node"/}"
      rel="${rel%.*}"
      rel="${rel//\// }"
      case "$rel" in _self | *" _self") continue ;; esac # handlers get the footer
      case "$seen" in *"
$rel
"*) continue ;; esac # shadowed by a more specific tree
      seen="$seen$rel
"
      if [ "$tag" = "core" ]; then
        printf '  %-22s %s\n' "$rel" "$(meta "$f" description)"
      else
        printf '  %-22s %s [%s]\n' "$rel" "$(meta "$f" description)" "$tag"
      fi
    done < <(listScripts "$node")
  done < <(tissTrees)
  echo
  if [ -n "$ns" ]; then
    # A _self handler owns everything unmatched in this namespace.
    local handler=""
    while IFS= read -r tree; do
      if handler="$(findScript "$tree/scripts${ns:+/${ns// /\/}}" _self)"; then
        break
      fi
      handler=""
    done < <(tissTrees)
    if [ -n "$handler" ]; then
      echo "Anything else: $(meta "$handler" description)"
    else
      echo "Anything else passes through to \`${ns%% *}\` itself."
    fi
  else
    echo "Anything else passes through to the underlying tool, installing it"
    echo "first if needed:  $TISS_NAME rg TODO   # installs ripgrep, runs it"
    echo
    echo "  $TISS_NAME --manifest   machine-readable command list (jsonl)"
  fi
}

# --- manifest ----------------------------------------------------------------
# One JSON object per command (jsonl), for AI agents and tooling. Merged
# across trees; each entry carries its source tree, shadowed entries drop.
manifest() {
  ensureTool jq || exit 127
  local tree root f cmd type seen="
"
  while IFS= read -r tree; do
    root="$tree/scripts"
    [ -d "$root" ] || continue
    while IFS= read -r f; do
      cmd="$(cmdOf "$root" "$f")"
      type="scripted"
      case "$cmd" in
        _self)
          cmd="*"
          type="handler"
          ;;
        *" _self")
          cmd="${cmd% _self} *"
          type="handler"
          ;;
      esac
      case "$seen" in *"
$cmd
"*) continue ;; esac
      seen="$seen$cmd
"
      jq -cn \
        --arg command "$cmd" \
        --arg type "$type" \
        --arg description "$(meta "$f" description)" \
        --arg usage "$(meta "$f" usage)" \
        --arg needs "$(meta "$f" needs)" \
        --arg examples "$(metaAll "$f" example)" \
        --arg source "${f#"$tree"/}" \
        --arg tree "$(treeTag "$tree")" \
        '{command: $command,
          type: $type,
          description: $description,
          usage: $usage,
          needs: ($needs | split(" ") | map(select(. != ""))),
          examples: ($examples | split("\n") | map(select(. != ""))),
          source: $source,
          tree: $tree}'
    done < <(listScripts "$root")
  done < <(tissTrees)
}

# --- shell completion ---------------------------------------------------------
# Called by the completion functions emitted by `tiss self completion`:
#   tiss --complete <completed words...>       plain candidates (bash)
#   tiss --complete-zsh <completed words...>   name:description pairs (zsh)
# Union of every tree's candidates at the walked node.
shellComplete() {
  local mode="$1" tree node w entry name seen="
" skip
  shift
  while IFS= read -r tree; do
    node="$tree/scripts"
    skip=0
    for w in "$@"; do
      [ -n "$w" ] || continue
      if [ -d "$node/$w" ]; then
        node="$node/$w"
      elif findScript "$node" "$w" >/dev/null 2>&1; then
        return 0 # inside a script's own args — nothing to add
      else
        skip=1
        break
      fi
    done
    [ "$skip" = 1 ] && continue
    for entry in "$node"/*; do
      [ -e "$entry" ] || continue
      name="$(basename "$entry")"
      case "$name" in _*) continue ;; esac # handlers/private files
      if [ -d "$entry" ]; then
        :
      elif [ -f "$entry" ] && [ -x "$entry" ]; then
        name="${name%.*}"
      else
        continue
      fi
      case "$seen" in *"
$name
"*) continue ;; esac
      seen="$seen$name
"
      if [ "$mode" = "zsh" ]; then
        if [ -d "$entry" ]; then
          printf '%s:%s\n' "$name" "($name commands)"
        else
          printf '%s:%s\n' "$name" "$(meta "$entry" description)"
        fi
      else
        printf '%s\n' "$name"
      fi
    done
  done < <(tissTrees)
}

# --- near-miss detection -------------------------------------------------------
# A file that WOULD have routed but isn't executable is the #1 "why doesn't
# my new command work" trap. Never fail silently: find it and say so.
findNearMiss() { # findNearMiss <args...> -> path of non-executable candidate
  local tree node w f
  while IFS= read -r tree; do
    node="$tree/scripts"
    for w in "$@"; do
      case "$w" in -*) break ;; esac
      for f in "$node/$w" "$node/$w".*; do
        if [ -f "$f" ] && [ ! -x "$f" ]; then
          printf '%s\n' "$f"
          return 0
        fi
      done
      [ -d "$node/$w" ] || break
      node="$node/$w"
    done
  done < <(tissTrees)
  return 1
}

# --- passthrough -------------------------------------------------------------
passthrough() { # passthrough <tool> [args...] — behave as if called natively
  local near
  if near="$(findNearMiss "$@")"; then
    if command -v "$(tissCommandAlias "$1")" >/dev/null 2>&1; then
      logWarn "'$near' would match this command but is not executable (chmod +x to activate it) — passing through"
    else
      logError "'$near' matches this command but is not executable."
      logError "activate it with:  chmod +x $near"
      exit 126
    fi
  fi
  # tool@version runs through mise without touching your global tools:
  # `tiss python@3.13 script.py` -> mise x python@3.13 -- python script.py
  case "$1" in
    *@?*)
      local spec="$1" base
      base="${spec%%@*}"
      shift
      if ! tissInstallAllowed "$base"; then
        logError "'$base' is not on the passthrough install allowlist (cfg TISS_INSTALL_ALLOW \"$base\")"
        exit 127
      fi
      ensureTool mise || exit 127
      exec mise x "$spec" -- "$base" "$@"
      ;;
  esac

  # Aliases may be multi-word: `tiss ssm ...` -> `aws ssm ...`
  local alias_cmd
  alias_cmd="$(tissCommandAlias "$1")"
  shift
  # shellcheck disable=SC2086  # word-splitting the alias is the point
  set -- $alias_cmd "$@"
  local tool="$1"
  shift
  ensureTool --gated "$tool" || exit 127
  exec "$tool" "$@"
}

# --- main --------------------------------------------------------------------
main() {
  # @<name> prefix: load that environment profile, then continue routing.
  # Bare `tiss @dev` drops into the dev shell inside the environment.
  local envName
  case "${1:-}" in
    @?*)
      envName="${1#@}"
      shift
      tissLoadEnv "$envName" || exit 2
      [ $# -gt 0 ] || set -- self shell
      ;;
  esac

  case "${1:-}" in
    "" | -h | --help)
      showHelp
      exit 0
      ;;
    help)
      # `tiss help` / `tiss help git clone` — help is a first-class word.
      shift
      if [ $# -eq 0 ]; then
        showHelp
        exit 0
      fi
      local tree nspath
      while IFS= read -r tree; do
        if resolveInTree "$tree/scripts" "$@"; then
          tissHelp "$RESOLVED_SCRIPT"
          exit 0
        fi
      done < <(tissTrees)
      nspath="$(printf '/%s' "$@")"
      while IFS= read -r tree; do
        if [ -d "$tree/scripts$nspath" ]; then
          showHelp "$@"
          exit 0
        fi
      done < <(tissTrees)
      logError "no tiss command '$*' — for a passthrough tool's own help try: $TISS_NAME $1 --help"
      exit 2
      ;;
    --manifest)
      manifest
      exit 0
      ;;
    --version | -V)
      echo "$TISS_NAME $(cat "$TISS_HOME/version.txt" 2>/dev/null || echo dev) ($TISS_HOME)"
      exit 0
      ;;
    --complete)
      shift
      shellComplete plain "$@"
      exit 0
      ;;
    --complete-zsh)
      shift
      shellComplete zsh "$@"
      exit 0
      ;;
  esac

  # First tree with a script match wins (overlay beats core).
  # NOTE: the tree list is read on fd 3, NOT stdin — a `while read` loop
  # redirected on fd 0 would replace stdin for the exec'd script and break
  # every pipe into a tiss command (found the hard way).
  local tree dep script
  while IFS= read -r tree <&3; do
    if resolveInTree "$tree/scripts" "$@"; then
      script="$RESOLVED_SCRIPT"
      shift "$RESOLVED_SHIFT"
      # Preflight: install whatever the script declares via `# @needs`
      # before it runs. (Asking for help never installs anything.)
      case "${1:-}" in
        -h | --help) ;;
        *)
          for dep in $(meta "$script" needs); do
            ensureTool "$dep" || exit 127
          done
          ;;
      esac
      exec 3<&-
      exec "$script" "$@"
    fi
  done 3< <(tissTrees)

  # Landed on a namespace (`tiss git`), or asked one for help
  # (`tiss self --help`, `tiss self help`): merged namespace help.
  # Any OTHER flag (`tiss git --version`) still passes through natively.
  local ns=() w trailing=""
  for w in "$@"; do
    case "$w" in
      -h | --help | help)
        trailing="help"
        break
        ;;
      -*)
        trailing="flag"
        break
        ;;
      *) ns+=("$w") ;;
    esac
  done
  if [ ${#ns[@]} -gt 0 ] && [ "$trailing" != "flag" ]; then
    local nspath
    nspath="$(printf '/%s' "${ns[@]}")"
    while IFS= read -r tree; do
      if [ -d "$tree/scripts$nspath" ]; then
        showHelp "${ns[@]}"
        exit 0
      fi
    done < <(tissTrees)
  fi

  # No script matched: behave as if the wrapped tool was called natively.
  passthrough "$@"
}

main "$@"
